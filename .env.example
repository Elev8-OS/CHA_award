# ============================================================================
# CHA AWARDS — Environment Variables
# Copy this to .env.local for development, set in Railway dashboard for production
# ============================================================================

# ----- Public Site -----
NEXT_PUBLIC_SITE_URL=https://awards.elev8-suite.com
NEXT_PUBLIC_APP_NAME="Canggu Host Awards"

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...                # ONLY server-side, never expose

# ----- Meta WhatsApp Cloud API -----
WHATSAPP_PHONE_NUMBER_ID=123456789012345              # from Meta Business Manager
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345          # WABA ID
WHATSAPP_ACCESS_TOKEN=EAAYourPermanentToken           # System User Access Token
WHATSAPP_VERIFY_TOKEN=your_random_webhook_verify_token # you choose this, set in Meta webhook
WHATSAPP_APP_SECRET=your_meta_app_secret              # for signature verification

# ----- Email (Resend) -----
RESEND_API_KEY=re_YourApiKey
RESEND_FROM_EMAIL="CHA Awards <awards@elev8-suite.com>"
RESEND_REPLY_TO=hello@elev8-suite.com

# ----- Admin Auth -----
# Comma-separated list of admin emails who can access /admin
ADMIN_ALLOWED_EMAILS=you@elev8-suite.com,reto.wyss@elev8-suite.com,prima@cha.id,maya@example.com,florian@gruenresorts.com

# ----- Anti-abuse / Privacy -----
IP_HASH_SALT=replace-with-random-string-for-ip-hashing

# ----- Application Settings -----
APPLICATIONS_OPEN_AT=2026-05-12T00:00:00+08:00
APPLICATIONS_CLOSE_AT=2026-05-22T23:59:59+08:00
FINALISTS_REVEAL_AT=2026-05-25T18:00:00+08:00
WINNERS_REVEAL_AT=2026-05-26T15:00:00+08:00

# ----- Optional: Analytics -----
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=awards.elev8-suite.com
